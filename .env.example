# Cerebras API (LLM inference)
CEREBRAS_API_KEY=your-cerebras-api-key-here
CEREBRAS_MODEL=gpt-oss-120b

# ENTSO-E API (day-ahead electricity prices)
ENTSOE_API_KEY=your-entsoe-api-key-here
BIDDING_ZONE=AT

# Optional: Virtual environment path (for local development)
# VENV_PATH=/path/to/your/venv

# Optional: Working directory override (set automatically in Docker)
# HEMS_WORK_DIR=/app

# Optional: Reasoning settings
# REASONING_EFFORT=high
# REASONING_FORMAT=parsed
